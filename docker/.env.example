# Local-dev-only values (Supabase's public demo JWT/keys — safe, never used against a real project).
# Copy to docker/.env before running `docker compose -f docker/docker-compose.yml --env-file docker/.env up -d`.

POSTGRES_PASSWORD=postgres
POSTGRES_DB=postgres

# Demo JWT secret + matching anon/service_role tokens, same ones the Supabase CLI uses locally.
JWT_SECRET=super-secret-jwt-token-with-at-least-32-characters-long
JWT_EXPIRY=3600
ANON_KEY=
SERVICE_ROLE_KEY=

SITE_URL=http://localhost:3000
ADDITIONAL_REDIRECT_URLS=http://localhost:3000/auth/callback,http://127.0.0.1:3000/auth/callback
API_EXTERNAL_URL=http://localhost:54321
SUPABASE_PUBLIC_URL=http://localhost:54321

# Basic-auth in front of Kong's dashboard route (Studio itself is exposed directly on 54323 without this).
DASHBOARD_USERNAME=supabase
DASHBOARD_PASSWORD=change-me

# Random 48+ byte secret for Realtime — generate with: openssl rand -base64 48
SECRET_KEY_BASE=

# --- app / migrate / cron services (containerize the Next.js app itself) ---

# Comma-separated allow-list of owner email(s) permitted past /login — same
# purpose as root .env.example's OWNER_EMAILS. No safe default; must be set.
OWNER_EMAILS=

# Shared secret the `cron` service sends as `Authorization: Bearer $CRON_SECRET`
# to `app`'s /api/cron/* routes — generate with: openssl rand -hex 32
CRON_SECRET=

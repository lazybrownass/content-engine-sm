# Pooled Postgres connection (Supabase transaction-mode pgbouncer) — used at runtime by Prisma Client.
DATABASE_URL=

# Direct Postgres connection (no pooler) — used only by `prisma migrate`.
DIRECT_URL=

# Supabase project URL — safe to expose to the browser.
NEXT_PUBLIC_SUPABASE_URL=

# Supabase anon/public API key — safe to expose to the browser, RLS enforces access.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase service role key — bypasses RLS, server-only, never sent to the client.
SUPABASE_SERVICE_ROLE_KEY=

# Comma-separated allow-list of owner email(s) permitted past /login (see middleware.ts).
OWNER_EMAILS=

# Hugging Face Inference API token — used by lib/ai/providers/huggingface.ts for
# embeddings (BAAI/bge-base-en-v1.5) and reranking (BAAI/bge-reranker-v2-m3), and by
# lib/ai/model-router.ts (via @ai-sdk/huggingface) for on-demand generation.
HUGGINGFACE_API_TOKEN=

# Shared secret Vercel Cron sends as `Authorization: Bearer $CRON_SECRET` — verified by
# app/api/cron/process-embeddings/route.ts before running (Vercel's standard cron-auth pattern).
CRON_SECRET=

# Hugging Face model id used by lib/ai/model-router.ts for the "brand-voice-generation"
# purpose. Optional — defaults to Qwen/Qwen2.5-72B-Instruct if unset.
GENERATION_MODEL=

# Hugging Face model id used by lib/ai/model-router.ts for the "inline_edit" purpose
# (in-editor rewrite/shorten/change-hook actions). A smaller/faster model than
# GENERATION_MODEL by design — these are latency-sensitive calls made while the owner
# waits. Optional — defaults to Qwen/Qwen2.5-7B-Instruct if unset.
INLINE_EDIT_MODEL=

# Selects which model provider lib/ai/model-router.ts's getModel() uses: "huggingface"
# (default) or "ollama". Set to "ollama" only after verifying a local Ollama server per
# docs/local-ollama-setup.md — this is a manual, explicit opt-in switch, never an
# automatic runtime fallback.
MODEL_PROVIDER=

# Base URL of the local Ollama OpenAI-compatible endpoint, used by
# lib/ai/model-router.ts when MODEL_PROVIDER=ollama. Optional — defaults to
# http://localhost:11434/v1 if unset.
OLLAMA_BASE_URL=

# Ollama model id used by lib/ai/model-router.ts when MODEL_PROVIDER=ollama. Optional —
# defaults to qwen2.5:7b-instruct-q4_K_M if unset (see docs/local-ollama-setup.md).
OLLAMA_MODEL=

# Set to any truthy value to swap in a hand-rolled, dependency-free canned-response model
# (lib/ai/mock-generation-model.ts) instead of a real HuggingFace call. Used only by the
# Playwright E2E run (tests/e2e/generate.spec.ts) so it stays hermetic and fast — never set
# this in a real environment.
E2E_MOCK_LLM=

# HMAC-SHA256 secret used by features/publishing/providers/n8n.provider.ts to sign
# outbound dispatch payloads and by app/api/webhooks/n8n/route.ts to verify inbound
# callbacks. AutomationProvider.signingSecretRef stores the *name* of this env var
# ("N8N_SIGNING_SECRET"), not the secret itself — the raw value never touches Postgres.
N8N_SIGNING_SECRET=

# Same purpose as N8N_SIGNING_SECRET, for features/publishing/providers/make.provider.ts
# and app/api/webhooks/make/route.ts.
MAKE_SIGNING_SECRET=

# Absolute origin of this app (e.g. https://yourapp.vercel.app), used to build the
# callbackUrl sent in outbound publishing-dispatch payloads so n8n/Make know where to
# call back.
APP_BASE_URL=

# Timeout (ms) for outbound n8n/Make webhook dispatch requests before treating the
# PublishingJob as FAILED. Optional — defaults to 10000 if unset.
PUBLISHING_DISPATCH_TIMEOUT_MS=

# Age threshold (minutes) after which a DISPATCHED PublishingJob with no callback is
# flipped to PUBLISH_UNCONFIRMED by the dispatch-publishing cron sweep, so a missing
# webhook callback never silently reads as a false "published". Optional — defaults to
# 30 if unset.
PUBLISHING_CALLBACK_TIMEOUT_MINUTES=

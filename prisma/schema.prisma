generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  directUrl  = env("DIRECT_URL")
  extensions = [vector, pgcrypto, pg_stat_statements, uuid_ossp(map: "uuid-ossp")]
}

model User {
  id          String   @id @default(dbgenerated("auth.uid()")) @db.Uuid
  email       String   @unique
  displayName String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  settings       Settings?
  knowledgeItems KnowledgeItem[]
  brandVoices    BrandVoice[]
  pipelineRuns   PipelineRun[]

  @@map("users")
}

model Settings {
  id      String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  ownerId String @unique @db.Uuid
  owner   User   @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  positioningStatement String?
  idealClientProfile   String?
  offers               Json     @default("[]")
  industriesServed     String[] @default([])
  targetAudienceNotes  String?
  painPointNotes       String?
  brandVoiceNotes      String?

  defaultPostLength    String @default("medium")
  weeklyPostingGoalMin Int    @default(3)
  weeklyPostingGoalMax Int    @default(5)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("settings")
}

// ─────────────────────────────────────────────────────────────────────────
// KNOWLEDGE BASE
// ─────────────────────────────────────────────────────────────────────────

enum KnowledgeCategory {
  PROJECT
  PRODUCT
  CASE_STUDY
  CLIENT_WIN
  LESSON_LEARNED
  SERVICE
  PORTFOLIO_ITEM
  FAQ
  WRITING_STYLE_NOTE
  BRAND_VOICE_NOTE
  INDUSTRY
  TARGET_CLIENT
  EXPERIENCE
  PREVIOUS_POST
  IDEA
}

enum Pillar {
  BUILD_IN_PUBLIC
  CASE_STUDY
  TECHNICAL_INSIGHT
  FOUNDER_STORY
  LESSON_LEARNED
  EDUCATIONAL
  MARKETING_BUSINESS_GROWTH
}

model KnowledgeItem {
  id          String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  ownerId     String            @db.Uuid
  owner       User              @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  category    KnowledgeCategory
  title       String
  body        String            // markdown source of truth
  tags        String[]          @default([])
  pillarHints Pillar[]          @default([])

  sourceUrl   String?           // optional link to original artifact (proposal doc, etc.)
  archived    Boolean           @default(false)

  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  chunks      KnowledgeChunk[]

  @@index([ownerId, category])
  @@index([ownerId, archived])
  @@map("knowledge_items")
}

model KnowledgeChunk {
  id              String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  knowledgeItemId String        @db.Uuid
  knowledgeItem   KnowledgeItem @relation(fields: [knowledgeItemId], references: [id], onDelete: Cascade)

  ordinal         Int           // position within the parent item
  content         String
  embedding       Unsupported("vector(768)")? // bge-base-en-v1.5 = 768 dims
  embeddingModel  String?       // e.g. "BAAI/bge-base-en-v1.5"
  embeddingStatus String        @default("pending") // pending | ready | failed

  createdAt       DateTime      @default(now())

  @@index([knowledgeItemId])
  @@index([embeddingStatus, createdAt])
  @@map("knowledge_chunks")
}

// ─────────────────────────────────────────────────────────────────────────
// BRAND VOICE
//
// A manually-authored style config the owner can name and switch between
// (tone/forbidden words/signature hooks/formatting rules), distinct from the
// documented but not-yet-built DomainContext (industry vocabulary/tone/
// compliance, docs/05-Backend-Schema.md) and StyleMemoryProfile (writing
// style learned from post history). Introduced ahead of the pipeline as a
// documented out-of-order insertion — see docs/06-Implementation-Plan.md's
// "Phase 2.5" section.
// ─────────────────────────────────────────────────────────────────────────

model BrandVoice {
  id      String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  ownerId String @db.Uuid
  owner   User   @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  name            String
  tone            String[] @default([])
  targetAudience  String?
  forbiddenWords  String[] @default([])
  signatureHooks  String[] @default([])
  formattingRules String[] @default([])
  isDefault       Boolean  @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([ownerId])
  @@map("brand_voices")
}

// ─────────────────────────────────────────────────────────────────────────
// PIPELINE CORE (Phase 2, partial — scoped slice)
//
// A reduced, standalone slice of the full 12-stage pipeline documented in
// docs/05-Backend-Schema.md: only OUTLINE -> DRAFT -> GRILL_REVIEW exist here.
// PipelineRun uses a direct ownerId (not postId) because no Post/Topic model
// exists yet — see docs/05-Backend-Schema.md's deviation note above the
// aspirational PipelineRun/AiRun definitions. Not wired into any route or UI.
// ─────────────────────────────────────────────────────────────────────────

enum PipelineStage {
  OUTLINE
  DRAFT
  GRILL_REVIEW
}

enum PipelineRunStatus {
  QUEUED
  RUNNING
  PAUSED
  FAILED
  COMPLETED
}

enum AiRunStatus {
  SUCCESS
  FAILED
  TIMEOUT
  RATE_LIMITED
}

model PipelineRun {
  id      String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  ownerId String @db.Uuid
  owner   User   @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  status       PipelineRunStatus @default(QUEUED)
  currentStage PipelineStage?
  retryCount   Int               @default(0)
  lastError    String?

  qualityScore Int?
  grillCycles  Int    @default(0)

  startedAt   DateTime?
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  aiRuns AiRun[]

  @@index([ownerId])
  @@index([ownerId, status])
  @@map("pipeline_runs")
}

model AiRun {
  id            String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  pipelineRunId String      @db.Uuid
  pipelineRun   PipelineRun @relation(fields: [pipelineRunId], references: [id], onDelete: Cascade)

  stage        PipelineStage
  modelId      String
  status       AiRunStatus
  inputTokens  Int?
  outputTokens Int?
  latencyMs    Int?
  costUsd      Decimal       @default(0) @db.Decimal(10, 6)
  errorMessage String?

  createdAt DateTime @default(now())

  @@index([pipelineRunId])
  @@index([stage, status])
  @@map("ai_runs")
}

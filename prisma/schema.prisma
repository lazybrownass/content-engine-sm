generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  directUrl  = env("DIRECT_URL")
  extensions = [vector, pgcrypto, pg_stat_statements, uuid_ossp(map: "uuid-ossp")]
}

model User {
  id          String   @id @default(dbgenerated("auth.uid()")) @db.Uuid
  email       String   @unique
  displayName String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  settings            Settings?
  knowledgeItems      KnowledgeItem[]
  brandVoices         BrandVoice[]
  pipelineRuns        PipelineRun[]
  topics              Topic[]
  posts               Post[]
  automationProviders AutomationProvider[]

  @@map("users")
}

model Settings {
  id      String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  ownerId String @unique @db.Uuid
  owner   User   @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  positioningStatement String?
  idealClientProfile   String?
  offers               Json     @default("[]")
  industriesServed     String[] @default([])
  targetAudienceNotes  String?
  painPointNotes       String?
  brandVoiceNotes      String?

  defaultPostLength    String @default("medium")
  weeklyPostingGoalMin Int    @default(3)
  weeklyPostingGoalMax Int    @default(5)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("settings")
}

// ─────────────────────────────────────────────────────────────────────────
// KNOWLEDGE BASE
// ─────────────────────────────────────────────────────────────────────────

enum KnowledgeCategory {
  PROJECT
  PRODUCT
  CASE_STUDY
  CLIENT_WIN
  LESSON_LEARNED
  SERVICE
  PORTFOLIO_ITEM
  FAQ
  WRITING_STYLE_NOTE
  BRAND_VOICE_NOTE
  INDUSTRY
  TARGET_CLIENT
  EXPERIENCE
  PREVIOUS_POST
  IDEA
}

enum Pillar {
  BUILD_IN_PUBLIC
  CASE_STUDY
  TECHNICAL_INSIGHT
  FOUNDER_STORY
  LESSON_LEARNED
  EDUCATIONAL
  MARKETING_BUSINESS_GROWTH
}

model KnowledgeItem {
  id      String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  ownerId String @db.Uuid
  owner   User   @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  category    KnowledgeCategory
  title       String
  body        String // markdown source of truth
  tags        String[]          @default([])
  pillarHints Pillar[]          @default([])

  sourceUrl String? // optional link to original artifact (proposal doc, etc.)
  archived  Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  chunks KnowledgeChunk[]

  @@index([ownerId, category])
  @@index([ownerId, archived])
  @@map("knowledge_items")
}

model KnowledgeChunk {
  id              String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  knowledgeItemId String        @db.Uuid
  knowledgeItem   KnowledgeItem @relation(fields: [knowledgeItemId], references: [id], onDelete: Cascade)

  ordinal         Int // position within the parent item
  content         String
  embedding       Unsupported("vector(768)")? // bge-base-en-v1.5 = 768 dims
  embeddingModel  String? // e.g. "BAAI/bge-base-en-v1.5"
  embeddingStatus String                      @default("pending") // pending | ready | failed

  createdAt DateTime @default(now())

  @@index([knowledgeItemId])
  @@index([embeddingStatus, createdAt])
  @@map("knowledge_chunks")
}

// ─────────────────────────────────────────────────────────────────────────
// BRAND VOICE
//
// A manually-authored style config the owner can name and switch between
// (tone/forbidden words/signature hooks/formatting rules), distinct from the
// documented but not-yet-built DomainContext (industry vocabulary/tone/
// compliance, docs/05-Backend-Schema.md) and StyleMemoryProfile (writing
// style learned from post history). Introduced ahead of the pipeline as a
// documented out-of-order insertion — see docs/06-Implementation-Plan.md's
// "Phase 2.5" section.
// ─────────────────────────────────────────────────────────────────────────

model BrandVoice {
  id      String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  ownerId String @db.Uuid
  owner   User   @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  name            String
  tone            String[] @default([])
  targetAudience  String?
  forbiddenWords  String[] @default([])
  signatureHooks  String[] @default([])
  formattingRules String[] @default([])
  isDefault       Boolean  @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([ownerId])
  @@map("brand_voices")
}

// ─────────────────────────────────────────────────────────────────────────
// PIPELINE CORE (Phase 2/3, partial — scoped slice)
//
// A reduced slice of the full 12-stage pipeline documented in
// docs/05-Backend-Schema.md: OUTLINE/DRAFT/GRILL_REVIEW (the Grill
// self-critique loop) plus TOPIC_GENERATION and the three INLINE_* stages
// added in Phase 3 (partial) for topic suggestions and in-editor AI actions.
// PipelineRun.postId/topicId are optional — the original outline/draft/grill
// loop predates Post/Topic and still runs standalone (no purpose field: the
// combination of currentStage + postId/topicId disambiguates what a run is
// for, see docs/05-Backend-Schema.md's deviation note). Not wired into a
// user-facing route for OUTLINE/DRAFT/GRILL_REVIEW directly; TOPIC_GENERATION
// and INLINE_* are invoked from features/topics and features/posts.
// ─────────────────────────────────────────────────────────────────────────

enum PipelineStage {
  OUTLINE
  DRAFT
  GRILL_REVIEW
  TOPIC_GENERATION
  INLINE_REWRITE
  INLINE_SHORTEN
  INLINE_CHANGE_HOOK
}

enum PipelineRunStatus {
  QUEUED
  RUNNING
  PAUSED
  FAILED
  COMPLETED
}

enum AiRunStatus {
  SUCCESS
  FAILED
  TIMEOUT
  RATE_LIMITED
}

model PipelineRun {
  id      String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  ownerId String @db.Uuid
  owner   User   @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  postId  String? @db.Uuid
  post    Post?   @relation(fields: [postId], references: [id], onDelete: Cascade)
  topicId String? @db.Uuid
  topic   Topic?  @relation(fields: [topicId], references: [id], onDelete: Cascade)

  status       PipelineRunStatus @default(QUEUED)
  currentStage PipelineStage?
  retryCount   Int               @default(0)
  lastError    String?

  qualityScore Int?
  grillCycles  Int  @default(0)

  startedAt   DateTime?
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  aiRuns AiRun[]

  @@index([ownerId])
  @@index([ownerId, status])
  @@index([postId])
  @@index([topicId])
  @@map("pipeline_runs")
}

model AiRun {
  id            String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  pipelineRunId String      @db.Uuid
  pipelineRun   PipelineRun @relation(fields: [pipelineRunId], references: [id], onDelete: Cascade)

  stage        PipelineStage
  modelId      String
  status       AiRunStatus
  inputTokens  Int?
  outputTokens Int?
  latencyMs    Int?
  costUsd      Decimal       @default(0) @db.Decimal(10, 6)
  errorMessage String?

  createdAt DateTime @default(now())

  @@index([pipelineRunId])
  @@index([stage, status])
  @@map("ai_runs")
}

// ─────────────────────────────────────────────────────────────────────────
// TOPICS & POSTS (Phase 3, partial — scoped slice)
//
// A trimmed version of the aspirational Topic/Post models in
// docs/05-Backend-Schema.md: no domainContextId (DomainContext deferred), no
// media/versions/schedule/analytics/feedback/styleExamples relations (all
// deferred models), no ctaText (CTA_GENERATION stage deferred), no separate
// archived boolean on Post (status = ARCHIVED is the single source of
// truth). TopicStatus drops EXPIRED and Post.status drops the
// scheduling/publishing values and GRILLING/REJECTED — every remaining enum
// value has a real code path this phase; both enums extend additively via
// ALTER TYPE ... ADD VALUE when the deferred features are built, the same
// way PipelineStage already grew from 3 to 7 values above. See
// docs/05-Backend-Schema.md's "Implementation note (Phase 3, partial)".
// ─────────────────────────────────────────────────────────────────────────

enum TopicStatus {
  SUGGESTED
  ACCEPTED
  REJECTED
}

enum PostStatus {
  DRAFT
  PIPELINE_RUNNING
  NEEDS_OWNER_REVIEW
  IN_EDIT
  APPROVED
  SCHEDULED
  PUBLISHING
  PUBLISHED
  PUBLISH_UNCONFIRMED
  FAILED
  ARCHIVED
}

model Topic {
  id      String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  ownerId String @db.Uuid
  owner   User   @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  title              String
  rationale          String
  pillar             Pillar
  sourceKnowledgeIds String[]    @default([])
  score              Float?
  status             TopicStatus @default(SUGGESTED)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  post         Post?
  pipelineRuns PipelineRun[]

  @@index([ownerId, status])
  @@map("topics")
}

model Post {
  id      String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  ownerId String  @db.Uuid
  owner   User    @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  topicId String? @unique @db.Uuid
  topic   Topic?  @relation(fields: [topicId], references: [id], onDelete: SetNull)

  pillar Pillar
  status PostStatus @default(DRAFT)

  finalText    String?
  wordCount    Int?
  qualityScore Int?
  grillCycles  Int     @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  pipelineRuns PipelineRun[]
  schedule     Schedule?

  @@index([ownerId, status])
  @@index([ownerId, pillar])
  @@map("posts")
}

// ─────────────────────────────────────────────────────────────────────────
// SCHEDULING & PUBLISHING (Phase 4, partial — scoped slice)
//
// A reduced slice of the full docs/05-Backend-Schema.md design: three
// providers (MANUAL, N8N, MAKE) — PLAYWRIGHT is deferred (no browser-worker
// infra exists yet). AutomationProvider.configRef holds the literal webhook
// URL (not secret); signingSecretRef holds the *name* of an env var holding
// the real HMAC secret (e.g. "N8N_SIGNING_SECRET"), not a secrets-vault
// reference — this repo's existing "secrets store" is env vars (see
// HUGGINGFACE_API_TOKEN), and a real vault integration is out of scope.
// Schedule/PublishingJob have no direct ownerId column; ownership is proven
// via a join (Schedule -> Post.ownerId, PublishingJob -> AutomationProvider.
// ownerId), the same reasoning already used for ai_runs -> pipeline_runs
// above — low-volume, solo-owner tables where a join costs nothing.
// PostStatus gains SCHEDULED/PUBLISHING/PUBLISHED/PUBLISH_UNCONFIRMED only —
// GRILLING and REJECTED remain out of scope (see Phase 3's deviation note
// above). Deferred entirely this phase: full AutomationProvider CRUD UI
// (a minimal embedded create/test-ping form stands in for it), DomainContext,
// GeneratedMedia, PostVersion, Playwright provider/adapter, publish analytics.
// ─────────────────────────────────────────────────────────────────────────

enum PublishingProviderType {
  MANUAL
  N8N
  MAKE
}

enum PublishingJobStatus {
  SCHEDULED
  DISPATCHED
  PUBLISHED
  PUBLISH_UNCONFIRMED
  FAILED
  CANCELLED
}

model Schedule {
  id     String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  postId String @unique @db.Uuid
  post   Post   @relation(fields: [postId], references: [id], onDelete: Cascade)

  scheduledAt DateTime
  timezone    String   @default("UTC")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  jobs PublishingJob[]

  @@index([scheduledAt])
  @@map("schedules")
}

model AutomationProvider {
  id      String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  ownerId String @db.Uuid
  owner   User   @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  type             PublishingProviderType
  label            String
  isActive         Boolean                @default(false)
  isDefault        Boolean                @default(false)
  configRef        String?
  signingSecretRef String?
  lastTestedAt     DateTime?
  lastTestOk       Boolean?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  jobs PublishingJob[]

  @@index([ownerId, type])
  @@map("automation_providers")
}

model PublishingJob {
  id                   String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  scheduleId           String             @db.Uuid
  schedule             Schedule           @relation(fields: [scheduleId], references: [id], onDelete: Cascade)
  automationProviderId String             @db.Uuid
  automationProvider   AutomationProvider @relation(fields: [automationProviderId], references: [id])

  status       PublishingJobStatus @default(SCHEDULED)
  dispatchedAt DateTime?
  confirmedAt  DateTime?
  linkedinUrl  String?
  errorMessage String?
  attempt      Int                 @default(1)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@map("publishing_jobs")
}
